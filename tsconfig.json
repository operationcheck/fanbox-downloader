{
	"compilerOptions": {
		"target": "ES2023",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["DOM", "ES2023"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"isolatedModules": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "vite.config.ts"]
}
